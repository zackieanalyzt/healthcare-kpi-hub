NODE_ENV=development
API_PORT=3000
SQLITE_PATH=./data/app.db
AUTH_PROVIDER=dev
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=personnel
MARIADB_USER=change_me
MARIADB_PASSWORD=change_me
MARIADB_AUTH_TABLE=personnel_accounts
MARIADB_USERNAME_COLUMN=username
MARIADB_PASSWORD_COLUMN=password_hash
# Use MARIADB_FULL_NAME_COLUMN or both MARIADB_FIRST_NAME_COLUMN and MARIADB_LAST_NAME_COLUMN
# Set MARIADB_ACTIVE_COLUMN=none when the upstream schema has no active/status field
MARIADB_ACTIVE_COLUMN=is_active
MARIADB_FULL_NAME_COLUMN=full_name
MARIADB_FIRST_NAME_COLUMN=
MARIADB_LAST_NAME_COLUMN=
MARIADB_PASSWORD_HASH_MODE=bcrypt
SESSION_COOKIE_NAME=healthcare_kpi_hub_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_PATH=/
CSRF_COOKIE_NAME=healthcare_kpi_hub_csrf
CSRF_COOKIE_SAMESITE=Lax
CSRF_HEADER_NAME=X-CSRF-Token
SESSION_ABSOLUTE_LIFETIME_HOURS=12
SESSION_IDLE_TIMEOUT_HOURS=2
DEV_AUTH_PASSWORD=dev-password
LOG_LEVEL=INFO
